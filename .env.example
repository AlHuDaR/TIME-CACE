# Core backend settings
PORT=3000
RECEIVER_ENABLED=true
GPS_HOST=192.168.1.10
GPS_PORT=23
GPS_USERNAME=admin
GPS_PASSWORD=change-me
# XLi web telemetry (dashboard GPS receiver detail card inputs)
XLI_WEB_ENABLED=true
XLI_WEB_BASE_URL=http://192.168.50.2
XLI_GPS_SLOT=1
ALLOWED_ORIGIN=http://localhost:5500
SERVE_STATIC=true
NODE_ENV=development

# Optional backend tuning
MIN_CONNECTION_INTERVAL_MS=1000
REQUEST_TIMEOUT_MS=3000
RECEIVER_STATUS_CACHE_MS=4000
STATUS_STALE_MS=45000
RECEIVER_RECONNECT_INITIAL_MS=1000
RECEIVER_RECONNECT_MAX_MS=15000
GPS_DETAIL_CACHE_MS=30000
NTP_TIMEOUT_MS=1500
HTTPS_TIME_API_TIMEOUT_MS=2000
HTTP_DATE_TIMEOUT_MS=2000
NTP_NIST_HOSTS=time.nist.gov,time-a-g.nist.gov
NTP_NPL_HOSTS=time.nplindia.org,samay1.nic.in
WORLD_TIME_API_URLS=https://worldtimeapi.org/api/timezone/Asia/Muscat
TIMEAPI_IO_URLS=https://timeapi.io/api/Time/current/zone?timeZone=Asia/Muscat
HTTP_DATE_URLS=https://www.google.com,https://www.microsoft.com

# Optional API protection for external deployments
API_AUTH_ENABLED=false
API_AUTH_TOKEN=replace-with-a-long-random-token
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_TIME_MAX=90
RATE_LIMIT_STATUS_MAX=30
RATE_LIMIT_INTERNET_MAX=60
RATE_LIMIT_SET_MAX=8
