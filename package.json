{
  "name": "rafo-gps-time-display",
  "version": "1.1.0",
  "description": "RAFO Calibration Center Oman time display with a Netlify frontend and Express GPS proxy backend",
  "main": "gps-proxy.js",
  "scripts": {
    "start": "node gps-proxy.js",
    "dev": "nodemon gps-proxy.js",
    "start:api": "SERVE_STATIC=false NODE_ENV=production node gps-proxy.js",
    "start:full": "SERVE_STATIC=true node gps-proxy.js",
    "check": "node --check gps-proxy.js && node --check script.js",
    "test:protocol": "node tests/protocol-harness.js",
    "test": "npm run test:protocol"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
